# Reproducible installs: never run lifecycle scripts during dependency
# resolution. Reviewed scripts (build/test/etc) are invoked explicitly via
# npm run <script>. Override per-install with `--ignore-scripts=false` only
# when a script has been explicitly reviewed and approved.
ignore-scripts=true

# Storybook 8.6.x/9.x declare React as a peer of "^19.0.0-beta", which npm
# semver treats as a pre-release-only range that does NOT match stable
# React 19.2.x. This is an overly conservative upstream peer declaration;
# Storybook runs correctly on React 19 stable. The PUBLISHED aapaetsch-ui-kit
# package declares peer react "^19.2.0" and is independently verified. This
# dev-tooling peer discrepancy is documented as a non-blocking residual in
# docs/handoff-react19.md. We therefore do not abort installs on peer
# conflicts that originate solely from dev tooling.
strict-peer=false